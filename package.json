{
  "name": "to-notion-bot",
  "type": "module",
  "version": "1.1.1",
  "private": true,
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "build:clean": "rm -rf dist",
    "build:compile": "tsc -p tsconfig.json",
    "build:copy-locales": "mkdir -p dist/bot/locales && cp -r src/bot/locales/*.ftl dist/bot/locales/",
    "build:copy-assets": "mkdir -p dist/assets && cp -r src/assets/* dist/assets/",
    "build": "bun run build:clean && bun run build:compile && bun run build:copy-locales && bun run build:copy-assets",
    "start": "bun dist/main.js",
    "start:dev": "DEBUG=grammy* bun --watch src/main.ts",
    "landing": "serve landing/public -l 8080",
    "format": "prettier --write src",
    "lint": "eslint ."
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/i18n": "^1.1.2",
    "@grammyjs/parse-mode": "^1.11.1",
    "@koa/bodyparser": "^5.1.1",
    "@koa/router": "^13.1.0",
    "@notionhq/client": "^2.2.15",
    "bottleneck": "^2.19.5",
    "drizzle-orm": "^0.38.4",
    "got": "^14.4.5",
    "grammy": "^1.39.3",
    "koa": "^2.15.3",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "posthog-node": "^5.45.2",
    "serialize-error": "^12.0.0",
    "znv": "^0.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@ngrok/ngrok": "^1.4.1",
    "@types/bun": "^1.3.14",
    "@types/koa": "^2.15.0",
    "@types/koa__router": "^12.0.4",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.30.2",
    "eslint": "^9.19.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "serve": "^14.2.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
